# Copy to .env.local for local dev (never commit secrets).
# On AWS Amplify: set the same keys under App → Hosting → Environment variables
# (must be present at build time for Vite — redeploy after changing).

# Backend API origin (no trailing slash). Required in production builds.
VITE_API_BASE_URL=https://your-api.example.com

# --- Sign-in (required for login to work) ---
VITE_LOGIN_USERNAME=resourcing
# Plain password — letters/numbers only is simplest for Amplify & .env (no quotes needed).
VITE_LOGIN_PASSWORD=yourSecurePasswordHere
# Optional: only if the password must include # or other tricky characters — use Base64 instead of VITE_LOGIN_PASSWORD
# VITE_LOGIN_PASSWORD_B64=...

# Optional hardening (defaults shown)
# VITE_LOGIN_MAX_ATTEMPTS=5
# VITE_LOGIN_LOCKOUT_MS=900000
# VITE_SESSION_MAX_AGE_MS=28800000
